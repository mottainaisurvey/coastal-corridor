// Coastal Corridor Platform — Database Schema
// PostgreSQL + PostGIS
// ---
// Design principles:
// - All money amounts stored as BigInt (kobo/pence) to avoid float precision issues
//   EXCEPTION: Stays/Experiences amounts use Decimal for multi-currency compatibility
// - Spatial data uses PostGIS; not fully expressed here (Prisma limited) but noted
// - Soft-delete via deletedAt for most entities; hard delete only for transient data
// - Audit trail on every critical entity (createdBy, updatedBy, version)
// - Separate Identity from Profile to allow identity provider changes
// ---
// Status: v0.2 — Phase A additions: Stays, Experiences, Owambe integration infrastructure
// Schema is additive — all existing models preserved unchanged.

generator client {
  provider = "prisma-client-js"
}

model Config {
  key   String @id
  value String
}

// Enable PostGIS extension
generator extensions {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================================================
// IDENTITY & USERS
// =========================================================

enum UserRole {
  BUYER
  AGENT
  DEVELOPER
  TOUR_OPERATOR
  ADMIN
  GOVERNMENT
  VERIFIER
  // Phase A additions — Stays and Experiences verticals
  HOST
  OPERATOR
  GUEST
  PARTICIPANT
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  CLOSED
}

// Phase A addition — multi-currency support for Stays/Experiences
enum Currency {
  NGN
  USD
  GBP
}

// Phase A addition — cohort membership types
enum CohortType {
  COASTAL_CORRIDOR_HOST
  COASTAL_CORRIDOR_OPERATOR
  BOTH
}

// Phase A addition — cohort code lifecycle
enum CohortCodeStatus {
  ACTIVE
  USED
  REVOKED
}

model User {
  id              String     @id @default(cuid())
  clerkId         String?    @unique
  email           String     @unique
  phone           String?    @unique
  role            UserRole   @default(BUYER)
  status          UserStatus @default(PENDING_VERIFICATION)
  emailVerified   DateTime?
  phoneVerified   DateTime?
  kycStatus       String?    // references KycRecord
  diasporaCountry String?    // ISO country code if diaspora buyer
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  // Phase A additions — all nullable for backward compatibility
  preferredCurrency    Currency  @default(NGN)
  cohortMember         Boolean   @default(false)
  cohortCode           String?
  cohortType           CohortType?
  cohortStartDate      DateTime?
  cohortEndDate        DateTime?
  owambeUserId         String?   @unique  // FK reference to Owambe User
  paystackCustomerCode String?            // Paystack customer code for Stays/Experiences

  profile          Profile?
  agentProfile     AgentProfile?
  devProfile       DeveloperProfile?
  hostProfile      HostProfile?
  operatorProfile  OperatorProfile?
  savedPlots       SavedPlot[]
  inquiries        Inquiry[]
  transactions     Transaction[]  @relation("TransactionBuyer")
  listings         Listing[]      @relation("ListingOwner")
  auditEntries     AuditEntry[]
  fractionalShares FractionalShare[]
  // Phase A additions
  stayProperties   StayProperty[]
  experiences      Experience[]
  reservations     Reservation[]  @relation("ReservationGuest")
  experienceBookings ExperienceBooking[] @relation("BookingParticipant")

  @@index([role, status])
  @@index([diasporaCountry])
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  avatar    String?
  bio       String?
  language  String   @default("en")
  currency  String   @default("NGN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNumber   String    @unique // ESVARBON registration
  licenseVerified Boolean   @default(false)
  licenseExpiry   DateTime?
  agencyName      String?
  yearsActive     Int?
  specialties     String[]  // e.g., ["residential", "commercial", "land"]
  regionsCovered  String[]  // Nigerian states
  rating          Float?
  reviewCount     Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  listings Listing[]
}

model DeveloperProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName  String
  cacNumber    String   @unique // Corporate Affairs Commission
  tin          String?  // Tax identification
  yearFounded  Int?
  description  String?
  projectCount Int      @default(0)
  verified     Boolean  @default(false)
  website      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projects Project[]
}

// Phase A addition — Host profile for Stays vertical
model HostProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName      String?
  businessName     String?
  bio              String?  @db.Text
  commissionRate   Decimal  @default(0.15) @db.Decimal(5, 4) // default 15%, negotiable
  paystackSubaccountCode String? // for commission splits at payment time
  verificationLevel VerificationLevel?
  verifiedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Phase A addition — Operator profile for Experiences vertical
model OperatorProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName      String?
  businessName     String?
  bio              String?  @db.Text
  commissionRate   Decimal  @default(0.15) @db.Decimal(5, 4) // default 15%, negotiable
  paystackSubaccountCode String? // for commission splits at payment time
  verificationLevel VerificationLevel?
  verifiedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// =========================================================
// CORRIDOR GEOGRAPHY
// =========================================================

enum DestinationType {
  INFRASTRUCTURE
  REAL_ESTATE
  MIXED_USE
  TOURISM
}

model Destination {
  id          String          @id @default(cuid())
  slug        String          @unique
  name        String
  state       String
  type        DestinationType
  latitude    Float
  longitude   Float
  description String
  heroImage   String?
  corridorKm  Float           // distance from VI terminus
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  plots             Plot[]
  projects          Project[]
  pois              PointOfInterest[]
  stats             DestinationStat[]
  fractionalSchemes FractionalScheme[]

  @@index([type])
  @@index([state])
}

model DestinationStat {
  id             String      @id @default(cuid())
  destinationId  String
  destination    Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  label          String
  value          String
  unit           String?
  displayOrder   Int         @default(0)

  @@index([destinationId])
}

model PointOfInterest {
  id            String          @id @default(cuid())
  destinationId String
  destination   Destination     @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  name          String
  category      String          // "beach", "market", "landmark", etc.
  latitude      Float
  longitude     Float
  description   String?
  createdAt     DateTime        @default(now())
}

// =========================================================
// REAL ESTATE: PARCELS, PROPERTIES, LISTINGS
// =========================================================

enum PlotStatus {
  AVAILABLE
  RESERVED
  SOLD
  DISPUTED
  UNDER_VERIFICATION
}

enum TitleStatus {
  PENDING
  VERIFIED
  DISPUTED
  REJECTED
}

enum TitleType {
  CERTIFICATE_OF_OCCUPANCY
  DEED_OF_ASSIGNMENT
  GAZETTE
  GOVERNOR_CONSENT
  GLOBAL_C_OF_O
  CUSTOMARY
}

model Plot {
  id             String      @id @default(cuid())
  plotId         String      @unique // Human-readable e.g., "LEKKI-0247"
  destinationId  String
  destination    Destination @relation(fields: [destinationId], references: [id])
  status         PlotStatus  @default(UNDER_VERIFICATION)

  // Location
  latitude       Float
  longitude      Float
  // Boundary geometry (PostGIS GEOGRAPHY type) — not in Prisma types; added via raw SQL
  // See /prisma/migrations for ALTER TABLE statement adding `boundary geometry(Polygon, 4326)`

  // Specs
  areaSqm        Float
  pricePerSqm    BigInt      // in kobo
  totalPrice     BigInt      // in kobo, computed but denormalized
  currency       String      @default("NGN")

  // Title
  titleStatus    TitleStatus @default(PENDING)
  titleType      TitleType?
  titleNumber    String?
  titleIssuer    String?     // e.g., "Lagos State Land Bureau"
  titleDocumentUrl String?   // secure S3 ref
  titleVerifiedAt DateTime?
  titleVerifiedBy String?    // userId of verifier

  // Risk scoring
  floodRiskScore     Int?    // 0-100
  erosionRiskScore   Int?    // 0-100
  disputeRiskScore   Int?    // 0-100
  accessibilityScore Int?    // 0-100

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  realEstateProperty RealEstateProperty?
  listings    Listing[]
  savedBy     SavedPlot[]
  inquiries   Inquiry[]
  verifications PlotVerification[]

  @@index([destinationId, status])
  @@index([titleStatus])
}

// Renamed from Property to RealEstateProperty to avoid collision with Stays StayProperty
// The original "Property" model is preserved with all its fields and relations intact.
enum RealEstatePropertyType {
  LAND_ONLY
  HOUSE
  APARTMENT
  COMMERCIAL
  MIXED_USE
  HOSPITALITY
}

model RealEstateProperty {
  id              String                 @id @default(cuid())
  plotId          String                 @unique
  plot            Plot                   @relation(fields: [plotId], references: [id])
  type            RealEstatePropertyType
  projectId       String?
  project         Project?               @relation(fields: [projectId], references: [id])
  title           String
  description     String
  bedrooms        Int?
  bathrooms       Int?
  floorArea       Float?       // sqm, built area if applicable
  yearBuilt       Int?
  amenities       String[]
  heroImage       String?
  images          String[]
  virtualTourUrl  String?      // Matterport / 360 tour
  floorPlanUrl    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  listings Listing[]

  @@index([type])
  @@index([projectId])
}

model Project {
  id                 String          @id @default(cuid())
  slug               String          @unique
  developerId        String
  developer          DeveloperProfile @relation(fields: [developerId], references: [id])
  destinationId      String
  destination        Destination     @relation(fields: [destinationId], references: [id])
  name               String
  description        String
  masterplanImage    String?
  totalUnits         Int
  availableUnits     Int
  priceFromKobo      BigInt
  priceToKobo        BigInt
  status             String          // "planning" | "active" | "sold_out" | "complete"
  completionDate     DateTime?
  amenities          String[]
  heroImage          String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  properties RealEstateProperty[]

  @@index([destinationId])
  @@index([status])
}

enum ListingStatus {
  DRAFT
  ACTIVE
  UNDER_OFFER
  SOLD
  WITHDRAWN
  EXPIRED
}

model Listing {
  id              String        @id @default(cuid())
  status          ListingStatus @default(DRAFT)
  plotId          String?
  plot            Plot?         @relation(fields: [plotId], references: [id])
  propertyId      String?
  property        RealEstateProperty? @relation(fields: [propertyId], references: [id])

  ownerId         String        // User who listed (could be agent, developer, or direct owner)
  owner           User          @relation("ListingOwner", fields: [ownerId], references: [id])
  agentId         String?
  agent           AgentProfile? @relation(fields: [agentId], references: [id])

  askingPriceKobo BigInt
  currency        String        @default("NGN")
  negotiable      Boolean       @default(false)
  description     String
  viewCount       Int           @default(0)
  inquiryCount    Int           @default(0)
  featured        Boolean       @default(false)
  expiresAt       DateTime?
  soldAt          DateTime?
  soldPriceKobo   BigInt?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  inquiries    Inquiry[]
  transactions Transaction[]

  @@index([status])
  @@index([ownerId])
  @@index([agentId])
}

model SavedPlot {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plotId    String
  plot      Plot     @relation(fields: [plotId], references: [id], onDelete: Cascade)
  note      String?
  createdAt DateTime @default(now())

  @@unique([userId, plotId])
}

// =========================================================
// INQUIRIES, TRANSACTIONS, VERIFICATION
// =========================================================

enum InquiryStatus {
  NEW
  CONTACTED
  VIEWING_SCHEDULED
  NEGOTIATING
  CONVERTED
  CLOSED_LOST
}

model Inquiry {
  id         String        @id @default(cuid())
  listingId  String
  listing    Listing       @relation(fields: [listingId], references: [id])
  plotId     String?
  plot       Plot?         @relation(fields: [plotId], references: [id])
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  status     InquiryStatus @default(NEW)
  message    String
  preferredContactMethod String @default("email")
  offeredPriceKobo BigInt?
  viewingScheduledAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

enum TransactionStatus {
  INITIATED
  ESCROW_FUNDED
  DOCUMENTS_REVIEW
  AWAITING_GOVT_CONSENT
  COMPLETED
  CANCELLED
  DISPUTED
}

// SECURITY NOTE: Transaction handling is a CRITICAL path.
// DO NOT use this schema to process real money without:
// - PCI-DSS review (if card data touched)
// - CBN FX compliance review (for diaspora inbound)
// - Legal review of escrow terms by Nigerian real estate counsel
// - Penetration testing of payment integration
// - Insurance (E&O + cyber) in place
model Transaction {
  id                 String            @id @default(cuid())
  reference          String            @unique // Human-readable txn ref
  listingId          String
  listing            Listing           @relation(fields: [listingId], references: [id])
  buyerId            String
  buyer              User              @relation("TransactionBuyer", fields: [buyerId], references: [id])
  status             TransactionStatus @default(INITIATED)

  agreedPriceKobo    BigInt
  currency           String            @default("NGN")
  escrowProvider     String?           // e.g., "Providus", "Sterling"
  escrowReference    String?
  escrowFundedAt     DateTime?

  legalRepUserId     String?           // If buyer has legal rep
  docsChecklistJson  String?           // JSON blob of doc checklist state

  completedAt        DateTime?
  cancelledAt        DateTime?
  cancelReason       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments Payment[]

  @@index([status])
  @@index([buyerId])
}

model Payment {
  id              String   @id @default(cuid())
  transactionId   String
  transaction     Transaction @relation(fields: [transactionId], references: [id])
  provider        String   // "paystack" | "flutterwave" | "stripe" | "bank_transfer"
  providerRef     String   @unique
  amountKobo      BigInt
  currency        String
  status          String   // "pending" | "successful" | "failed" | "refunded"
  method          String?  // "card" | "bank" | "ussd" | "transfer"
  rawProviderJson String?  // full provider response for audit
  processedAt     DateTime?
  createdAt       DateTime @default(now())
}

enum VerificationType {
  FIELD_VISIT
  TITLE_SEARCH
  BOUNDARY_CONFIRMATION
  COMMUNITY_CONSULTATION
  GOVERNMENT_RECORDS
}

// Phase A addition — verification levels for hosts, operators, and real estate agents
enum VerificationLevel {
  BASIC
  ENHANCED
  PREMIUM
}

model PlotVerification {
  id          String           @id @default(cuid())
  plotId      String
  plot        Plot             @relation(fields: [plotId], references: [id])
  type        VerificationType
  verifierId  String           // userId of verifier (role: VERIFIER)
  status      String           // "passed" | "failed" | "inconclusive"
  findings    String
  photos      String[]
  gpsLocation String?          // lat,lng of verifier at time of visit
  videoUrl    String?
  signedAt    DateTime?
  createdAt   DateTime         @default(now())

  @@index([plotId, type])
}

// =========================================================
// TOURISM VERTICAL (existing, preserved)
// =========================================================

model TourismListing {
  id            String   @id @default(cuid())
  operatorId    String
  destinationId String
  category      String   // "hotel" | "tour" | "experience" | "restaurant"
  name          String
  description   String
  pricePerNightKobo BigInt?
  capacity      Int?
  amenities     String[]
  images        String[]
  rating        Float?
  reviewCount   Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// =========================================================
// FRACTIONAL OWNERSHIP (existing, preserved)
// =========================================================

model FractionalScheme {
  id                    String      @id @default(cuid())
  slug                  String      @unique
  name                  String
  destinationId         String
  destination           Destination @relation(fields: [destinationId], references: [id])
  totalValueKobo        BigInt
  sharesIssued          Int
  sharesAvailable       Int
  pricePerShareKobo     BigInt
  currency              String      @default("NGN")
  projectedYield        Float       // annual % yield
  threeYearAppreciation Float       // % appreciation over 3 years
  lockupMonths          Int         @default(36)
  status                String      @default("ACTIVE") // ACTIVE | NEARLY_FULL | FULL | CLOSED
  description           String?
  imageUrl              String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  shares FractionalShare[]

  @@index([destinationId])
  @@index([status])
}

model FractionalShare {
  id          String           @id @default(cuid())
  schemeId    String
  scheme      FractionalScheme @relation(fields: [schemeId], references: [id])
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  quantity    Int
  priceKobo   BigInt           // price per share at time of purchase
  currency    String           @default("NGN")
  reference   String           @unique
  status      String           @default("ACTIVE") // ACTIVE | TRANSFERRED | REDEEMED
  purchasedAt DateTime         @default(now())
  maturesAt   DateTime?

  @@index([schemeId])
  @@index([userId])
}

// =========================================================
// STATE REGISTRY CONNECTORS (existing, preserved)
// =========================================================

model RegistryRecord {
  id          String   @id @default(cuid())
  registry    String   // "LASRERA" | "OGUNIRS" | "NIS" | "FMBN"
  externalId  String   // ID in the external registry
  plotId      String?  // linked plot if matched
  rawPayload  String   // JSON blob from registry
  status      String   @default("RECEIVED") // RECEIVED | MATCHED | UNMATCHED | ERROR
  matchedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([registry, externalId])
  @@index([registry])
  @@index([plotId])
}

// =========================================================
// OPERATOR & HOST APPLICATIONS (existing, extended)
// =========================================================

model OperatorApplication {
  id                   String   @id @default(cuid())
  path                 String   // "host" | "operator" | "both"
  fullName             String
  businessName         String?
  email                String
  phone                String
  corridorLocation     String
  countryOfResidence   String
  // Host-specific
  propertyType         String?
  numberOfRooms        Int?
  currentlyListedOn    String?
  // Operator-specific
  operationType        String?
  yearsOperating       Int?
  annualCustomers      String?
  // Shared open-text
  aboutOperation       String
  whyCoastalCorridor   String?
  additionalInfo       String?
  // Status
  status               String   @default("PENDING") // PENDING | REVIEWING | ACCEPTED | DECLINED
  reviewedAt           DateTime?
  reviewNotes          String?
  // Phase A addition — link to cohort code issued on acceptance
  cohortCodeId         String?  // FK to CohortCode.code (set when ACCEPTED)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([status])
  @@index([email])
  @@index([createdAt])
}

// =========================================================
// STAYS VERTICAL — Phase A additions
// =========================================================

enum StayPropertyType {
  BEACH_HOUSE
  GUESTHOUSE
  HOTEL
  SERVICED_APARTMENT
  RESORT
  HERITAGE
  OTHER
}

enum StayPropertyStatus {
  ACTIVE
  INACTIVE
  UNDER_REVIEW
}

enum RoomType {
  STANDARD
  DELUXE
  SUITE
  FAMILY
  ENTIRE_PROPERTY
  OTHER
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIALLY_PAID
  FAILED
  REFUNDED
}

// Stays property — sourced from Owambe via integration.
// Distinct from RealEstateProperty (real estate vertical).
model StayProperty {
  id                  String             @id @default(cuid())
  owambePropertyId    String             @unique  // source-of-truth reference
  hostUserId          String
  host                User               @relation(fields: [hostUserId], references: [id])
  name                String
  description         String             @db.Text
  propertyType        StayPropertyType
  addressLine1        String
  addressLine2        String?
  city                String
  state               String
  country             String             @default("Nigeria")
  latitude            Decimal            @db.Decimal(10, 7)
  longitude           Decimal            @db.Decimal(10, 7)
  amenities           String[]
  policies            Json               // check-in, check-out, cancellation, house rules, damage deposit
  status              StayPropertyStatus @default(UNDER_REVIEW)
  verificationLevel   VerificationLevel?
  verifiedAt          DateTime?
  rooms               Room[]
  reservations        Reservation[]
  images              StayPropertyImage[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([city, state])
  @@index([latitude, longitude])
}

model Room {
  id              String   @id @default(cuid())
  owambeRoomId    String   @unique
  propertyId      String
  property        StayProperty @relation(fields: [propertyId], references: [id])
  name            String
  roomType        RoomType
  capacity        Int
  baseRate        Decimal  @db.Decimal(10, 2)
  baseCurrency    Currency @default(NGN)
  amenities       String[]
  active          Boolean  @default(true)
  calendarEntries CalendarEntry[]
  reservations    Reservation[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CalendarEntry {
  id            String   @id @default(cuid())
  roomId        String
  room          Room     @relation(fields: [roomId], references: [id])
  date          DateTime @db.Date
  available     Boolean  @default(true)
  rate          Decimal? @db.Decimal(10, 2)
  currency      Currency @default(NGN)
  minimumStay   Int?     // nights
  maximumStay   Int?     // nights
  closedReason  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([roomId, date])
  @@index([roomId, date])
}

model Reservation {
  id                       String            @id @default(cuid())
  owambeReservationId      String?           @unique
  propertyId               String
  property                 StayProperty      @relation(fields: [propertyId], references: [id])
  roomId                   String
  room                     Room              @relation(fields: [roomId], references: [id])
  guestUserId              String
  guest                    User              @relation("ReservationGuest", fields: [guestUserId], references: [id])
  checkInDate              DateTime          @db.Date
  checkOutDate             DateTime          @db.Date
  numberOfGuests           Int
  totalAmount              Decimal           @db.Decimal(10, 2)
  currency                 Currency
  channelCommissionAmount  Decimal           @db.Decimal(10, 2)
  channelCommissionPercent Decimal           @db.Decimal(5, 2)
  netToHost                Decimal           @db.Decimal(10, 2)
  damageDeposit            Decimal?          @db.Decimal(10, 2)
  specialRequests          String?           @db.Text
  paystackReference        String?
  outboundIdempotencyKey   String?           @unique  // UUID v4 for outbound call to Owambe
  paymentStatus            PaymentStatus     @default(PENDING)
  status                   ReservationStatus @default(PENDING)
  cancellationReason       String?
  cancellationInitiatedBy  String?
  refundAmount             Decimal?          @db.Decimal(10, 2)
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  @@index([guestUserId])
  @@index([propertyId, checkInDate, checkOutDate])
}

model StayPropertyImage {
  id          String       @id @default(cuid())
  propertyId  String
  property    StayProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  url         String       // Supabase Storage URL
  caption     String?
  isPrimary   Boolean      @default(false)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
}

// =========================================================
// EXPERIENCES VERTICAL — Phase A additions
// =========================================================

enum ExperienceType {
  TOUR
  CHARTER
  WORKSHOP
  FOOD_EXPERIENCE
  TRANSPORT
  EVENT_SPECIALIST
  WELLNESS
  OTHER
}

enum ExperienceStatus {
  ACTIVE
  INACTIVE
  UNDER_REVIEW
}

enum PricingModel {
  PER_PERSON
  PER_GROUP
  TIERED
}

enum TimeSlotStatus {
  OPEN
  FULL
  CANCELLED
  COMPLETED
}

enum ExperienceBookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Experience {
  id                      String           @id @default(cuid())
  owambeExperienceId      String           @unique
  operatorUserId          String
  operator                User             @relation(fields: [operatorUserId], references: [id])
  name                    String
  description             String           @db.Text
  experienceType          ExperienceType
  durationMinutes         Int
  capacity                Int
  meetingPointDescription String
  meetingPointLatitude    Decimal          @db.Decimal(10, 7)
  meetingPointLongitude   Decimal          @db.Decimal(10, 7)
  pricingModel            PricingModel
  basePrice               Decimal          @db.Decimal(10, 2)
  baseCurrency            Currency         @default(NGN)
  ageRestriction          String?
  fitnessRequirement      String?
  weatherDependent        Boolean          @default(false)
  equipmentProvided       String[]
  equipmentRequired       String[]
  status                  ExperienceStatus @default(UNDER_REVIEW)
  verificationLevel       VerificationLevel?
  verifiedAt              DateTime?
  timeSlots               TimeSlot[]
  bookings                ExperienceBooking[]
  images                  ExperienceImage[]
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  @@index([meetingPointLatitude, meetingPointLongitude])
}

model TimeSlot {
  id                String         @id @default(cuid())
  owambeTimeSlotId  String         @unique
  experienceId      String
  experience        Experience     @relation(fields: [experienceId], references: [id])
  startDateTime     DateTime
  endDateTime       DateTime
  capacity          Int
  spotsBooked       Int            @default(0)
  rate              Decimal?       @db.Decimal(10, 2)
  currency          Currency       @default(NGN)
  recurrencePattern String?        // RFC 5545 RRULE if recurring
  status            TimeSlotStatus @default(OPEN)
  bookings          ExperienceBooking[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([experienceId, startDateTime])
}

model ExperienceBooking {
  id                       String                  @id @default(cuid())
  owambeBookingId          String?                 @unique
  experienceId             String
  experience               Experience              @relation(fields: [experienceId], references: [id])
  timeSlotId               String
  timeSlot                 TimeSlot                @relation(fields: [timeSlotId], references: [id])
  participantUserId        String
  participant              User                    @relation("BookingParticipant", fields: [participantUserId], references: [id])
  numberOfParticipants     Int
  participantNames         String[]
  totalAmount              Decimal                 @db.Decimal(10, 2)
  currency                 Currency
  channelCommissionAmount  Decimal                 @db.Decimal(10, 2)
  channelCommissionPercent Decimal                 @db.Decimal(5, 2)
  netToOperator            Decimal                 @db.Decimal(10, 2)
  specialRequirements      String?                 @db.Text
  pickupRequested          Boolean                 @default(false)
  pickupAddress            String?
  paystackReference        String?
  outboundIdempotencyKey   String?                 @unique  // UUID v4 for outbound call to Owambe
  paymentStatus            PaymentStatus           @default(PENDING)
  status                   ExperienceBookingStatus @default(PENDING)
  cancellationReason       String?
  cancellationInitiatedBy  String?
  refundAmount             Decimal?                @db.Decimal(10, 2)
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt

  @@index([participantUserId])
}

model ExperienceImage {
  id            String     @id @default(cuid())
  experienceId  String
  experience    Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  url           String
  caption       String?
  isPrimary     Boolean    @default(false)
  sortOrder     Int        @default(0)
  createdAt     DateTime   @default(now())
}

// =========================================================
// OWAMBE INTEGRATION INFRASTRUCTURE — Phase A additions
// =========================================================

model CohortCode {
  code                  String          @id  // e.g. CC-H4K2N9PX (host) or CC-O8M3R7QV (operator)
  cohortType            CohortType
  status                CohortCodeStatus @default(ACTIVE)
  issuedAt              DateTime        @default(now())
  expiresAt             DateTime?
  usedByUserId          String?
  usedAt                DateTime?
  notes                 String?         @db.Text
  operatorApplicationId String?         // FK to OperatorApplication.id if recruited via cohort
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([status])
  @@index([operatorApplicationId])
}

model IdempotencyCache {
  id              String   @id  // hash(idempotencyKey + endpointPath + bodyHash)
  idempotencyKey  String
  endpointPath    String
  bodyHash        String   // SHA-256 of request body
  responseStatus  Int
  responseBody    Bytes
  createdAt       DateTime @default(now())
  expiresAt       DateTime // createdAt + 7 days

  @@index([expiresAt])
  @@index([idempotencyKey])
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  DEAD_LETTER
}

model WebhookDelivery {
  id              String                @id @default(cuid())
  eventType       String
  eventId         String                @unique
  targetPlatform  String                // OWAMBE
  payload         Json
  signature       String
  status          WebhookDeliveryStatus @default(PENDING)
  attempts        Int                   @default(0)
  lastAttemptAt   DateTime?
  nextAttemptAt   DateTime?
  errorMessage    String?               @db.Text
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([status, nextAttemptAt])
}

model ReconciliationLog {
  id                String   @id @default(cuid())
  runAt             DateTime @default(now())
  scope             String   // STAYS | EXPERIENCES
  entitiesChecked   Int
  mismatchesFound   Int
  autoCorrected     Int
  manualReviewItems Int
  details           Json
  durationMs        Int
}

// =========================================================
// AUDIT & SYSTEM (existing, preserved)
// =========================================================

model AuditEntry {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  entityType String
  entityId   String
  action     String   // "create" | "update" | "delete" | "view"
  metadata   String?  // JSON
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}
