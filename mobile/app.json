{
  "expo": {
    "name": "Coastal Corridor",
    "slug": "coastal-corridor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0e12"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "africa.coastalcorridor.app",
      "buildNumber": "20",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0e12"
      },
      "package": "africa.coastalcorridor.app",
      "versionCode": 12
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "coastalcorridor",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "029072c2-e8b6-4e6e-8157-5eff2e52fb67"
      }
    },
    "owner": "owambeeventflow"
  }
}