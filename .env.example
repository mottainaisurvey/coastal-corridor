# ===== CORE =====
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ===== DATABASE (production) =====
# Enable PostGIS on your PostgreSQL instance before migrating.
# Recommended: Supabase, Neon, or AWS RDS in eu-west-2 or af-south-1
DATABASE_URL=postgresql://user:password@localhost:5432/corridor?schema=public

# ===== AUTHENTICATION (Clerk recommended for MVP) =====
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ===== MAPS =====
# Cesium Ion token (for premium 3D globe experience)
NEXT_PUBLIC_CESIUM_ION_TOKEN=
# Mapbox token (for production 2D maps if needed)
NEXT_PUBLIC_MAPBOX_TOKEN=

# ===== PAYMENTS =====
# Paystack (primary Nigerian rails)
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# Flutterwave (secondary, diaspora corridors)
FLUTTERWAVE_SECRET_KEY=
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=

# Stripe (international card processing via UK HoldCo)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ===== EMAIL =====
# Postmark for transactional
POSTMARK_API_TOKEN=
EMAIL_FROM=hello@coastalcorridor.co

# ===== STORAGE =====
# AWS S3 for documents (title deeds, contracts), images
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-2
S3_BUCKET_DOCUMENTS=
S3_BUCKET_IMAGES=

# ===== MONITORING =====
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ===== FEATURE FLAGS =====
FEATURE_TRANSACTIONS_LIVE=false
FEATURE_KYC_ENFORCEMENT=false
FEATURE_VR_INTEGRATION=false
